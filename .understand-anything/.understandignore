# .understandignore - patterns for files/dirs to exclude from analysis
# Syntax: same as .gitignore (globs, # comments, ! negation, trailing / for dirs)
#
# Keep the knowledge graph focused on hand-authored project structure.

.git/
.omx/
__pycache__/
*.py[cod]
build/
dist/

# Generated Qt resource bundle.
resource_rc.py

# Binary/static assets represented by resources/resource.qrc instead.
resources/images/
*.png
*.ico
*.ttf

# Runtime/local files.
dictionary/
prefs/config.xml
prefs/interface/sync.py
*.dct
